# Copy this file to /opt/mail-sentry/mail-sentry.env on the VM
# and replace the example values with the real deployment settings.

MAIL_SENTRY_PACKAGE_VERSION=0.1.1.dev0

MAIL_SENTRY_SERVER_HOST=0.0.0.0
MAIL_SENTRY_SERVER_PORT=8025
MAIL_SENTRY_SERVER_PATH=/mcp

MAIL_SENTRY_SMTP_HOST=smtp.example.com
MAIL_SENTRY_SMTP_PORT=587
MAIL_SENTRY_SMTP_AUTHENTICATE=true
MAIL_SENTRY_SMTP_USERNAME=bot@example.com
MAIL_SENTRY_SMTP_PASSWORD=replace-me
MAIL_SENTRY_SMTP_FROM_EMAIL=bot@example.com
MAIL_SENTRY_SMTP_FROM_NAME=Mail Sentry
MAIL_SENTRY_SMTP_TLS=starttls
MAIL_SENTRY_SMTP_VERIFY_PEER=true
MAIL_SENTRY_SMTP_TIMEOUT_SECONDS=30.0
