#!/usr/bin/env bash
set -euo pipefail

deploy_dir="${AGENT_ARBITER_DEPLOY_DIR:-/opt/agent-arbiter}"
source_dir="${AGENT_ARBITER_SOURCE_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}"
source_config="${AGENT_ARBITER_CONFIG_SOURCE:-$source_dir/config.yaml}"

compose_file="$deploy_dir/compose.yaml"
config_file="$deploy_dir/config.yaml"
env_file="$deploy_dir/agent-arbiter.env"
install_target_file="$deploy_dir/install-target"
empty_source_dir="$deploy_dir/empty-source"

usage() {
  cat <<'EOF'
Usage: agent-arbiterctl COMMAND

Commands:
  install [--force] [--install-target TARGET]
                Install root-owned deployment files under /opt/agent-arbiter
  edit-config   Edit /opt/agent-arbiter/config.yaml with the configured editor
  edit-env      Edit /opt/agent-arbiter/agent-arbiter.env with the configured editor
  protect       Reapply root ownership and restrictive file modes
  sync-env      Create or regenerate env keys from config, preserving values
  up            Start or update the Docker Compose service
  restart       Recreate the Docker Compose service
  down          Stop and remove the Docker Compose service
  ps            Show Docker Compose service status
  logs          Follow Docker Compose logs
  doctor        Show helper path and edit backend

Environment:
  AGENT_ARBITER_DEPLOY_DIR   Deployment directory, default /opt/agent-arbiter
  AGENT_ARBITER_SOURCE_DIR   Source deploy directory for install, default script dir
  AGENT_ARBITER_CONFIG_SOURCE Config file to install, default $AGENT_ARBITER_SOURCE_DIR/config.yaml
  AGENT_ARBITER_EDITOR       Editor for edit-config/edit-env
EOF
}

require_source_file() {
  local path="$1"
  [[ -f "$path" ]] || {
    printf 'error: missing source file: %s\n' "$path" >&2
    printf 'hint: run install from the repository deploy directory or set AGENT_ARBITER_SOURCE_DIR.\n' >&2
    exit 1
  }
}

require_deploy_file() {
  local path="$1"
  if sudo test -L "$path"; then
    printf 'error: refusing symlink deployment file: %s\n' "$path" >&2
    exit 1
  fi
  sudo test -f "$path" || {
    printf 'error: missing deployment file: %s\n' "$path" >&2
    printf 'hint: run: %s install\n' "$0" >&2
    exit 1
  }
}

backup_deploy_file() {
  local path="$1"
  local backup_file

  require_deploy_file "$path"
  backup_file="$path.bak.$(date +%Y%m%d%H%M%S)"
  sudo install -o root -g root -m 0600 "$path" "$backup_file"
  printf '%s\n' "$backup_file"
}

env_file_value() {
  local env_path="$1"
  local key="$2"
  [[ -f "$env_path" ]] || return 1

  awk -v key="$key" '
    BEGIN { found = 0 }
    $0 ~ "^[[:space:]]*#" { next }
    index($0, key "=") == 1 {
      print substr($0, length(key) + 2)
      found = 1
      exit
    }
    END {
      if (!found) {
        exit 1
      }
    }
  ' "$env_path"
}

package_version_to_install_target() {
  local version="$1"
  [[ -n "$version" ]] || return 1
  printf 'arbiter-suite==%s\n' "$version"
}

read_install_target_file() {
  require_deploy_file "$install_target_file"
  sudo awk 'NF { print; exit }' "$install_target_file"
}

write_install_target_file() {
  local target="$1"
  local tmp

  [[ -n "$target" ]] || {
    printf 'error: install target cannot be empty\n' >&2
    exit 2
  }

  tmp="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-install-target.XXXXXX")"
  trap 'rm -f "${tmp:-}"' EXIT
  printf '%s\n' "$target" >"$tmp"
  chmod 0600 "$tmp"
  sudo install -o root -g root -m 0444 "$tmp" "$install_target_file"
  rm -f "$tmp"
  trap - EXIT
}

existing_install_target() {
  local current_env_path="${1:-}"
  local target
  local version

  if sudo test -f "$install_target_file"; then
    target="$(read_install_target_file)"
    if [[ -n "$target" ]]; then
      printf '%s\n' "$target"
      return 0
    fi
  fi

  if [[ -n "$current_env_path" ]] && target="$(env_file_value "$current_env_path" AGENT_ARBITER_INSTALL_TARGET)"; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ -n "$current_env_path" ]] && version="$(env_file_value "$current_env_path" AGENT_ARBITER_PACKAGE_VERSION)"; then
    package_version_to_install_target "$version"
    return 0
  fi

  return 1
}

config_env_entries() {
  local path="$1"
  perl -0ne '
    while (/\$\{oc\.env:\s*([A-Za-z_][A-Za-z0-9_]*)(?:,([^}]*))?\}/g) {
      my ($name, $default) = ($1, defined($2) ? $2 : "");
      $default =~ s/^\s+|\s+$//g;
      next if $seen{$name}++;
      print "$name\t$default\n";
    }
  ' "$path"
}

write_env_template() {
  local config_path="$1"
  local output_path="$2"
  local existing_env_path="${3:-}"
  local name
  local default_value
  local env_value
  local value

  {
    printf '# Generated by agent-arbiterctl from %s\n' "$(basename "$config_path")"
    printf '# Fill empty values before starting the service.\n\n'

    while IFS=$'\t' read -r name default_value; do
      [[ -n "$name" ]] || continue
      if [[ "$name" == "AGENT_ARBITER_SERVER_HOST" ]]; then
        printf '# Docker must bind this service to 0.0.0.0 inside the container so the host can connect.\n'
        printf '# deploy/compose.yaml still publishes only on host 127.0.0.1, so it is not reachable off-host.\n'
      fi
      value="$default_value"
      if [[ -n "$existing_env_path" ]] && env_value="$(env_file_value "$existing_env_path" "$name")"; then
        value="$env_value"
      fi
      if [[ "$name" == "AGENT_ARBITER_SERVER_HOST" ]]; then
        value="0.0.0.0"
      fi
      printf '%s=%s\n' "$name" "$value"
    done < <(config_env_entries "$config_path")
  } >"$output_path"
}

require_deploy_dir() {
  if sudo test -L "$deploy_dir"; then
    printf 'error: refusing symlink deployment directory: %s\n' "$deploy_dir" >&2
    exit 1
  fi
  sudo test -d "$deploy_dir" || {
    printf 'error: missing deployment directory: %s\n' "$deploy_dir" >&2
    printf 'hint: run: %s install\n' "$0" >&2
    exit 1
  }
}

protect_files() {
  require_deploy_dir
  require_deploy_file "$compose_file"
  require_deploy_file "$config_file"
  require_deploy_file "$env_file"
  require_deploy_file "$install_target_file"
  sudo install -d -o root -g root -m 0755 "$empty_source_dir"
  sudo chown root:root "$deploy_dir" "$compose_file" "$config_file" \
    "$env_file" "$install_target_file"
  sudo chmod 0755 "$deploy_dir"
  sudo chmod 0755 "$empty_source_dir"
  sudo chmod 0444 "$compose_file" "$config_file" "$install_target_file"
  sudo chmod 0600 "$env_file"
}

run_editor() {
  local path="$1"
  local -a editor=()

  if [[ -n "${AGENT_ARBITER_EDITOR:-}" ]]; then
    read -r -a editor <<<"$AGENT_ARBITER_EDITOR"
  elif command -v vim >/dev/null 2>&1; then
    editor=(vim -Nu NONE -n -i NONE --cmd 'set t_SI= t_EI= t_SR= t_BE=')
  elif command -v vi >/dev/null 2>&1; then
    editor=(vi)
  else
    printf 'error: no editor found; set AGENT_ARBITER_EDITOR.\n' >&2
    return 1
  fi

  "${editor[@]}" "$path"
}

doctor() {
  printf 'script: %s\n' "$0"
  printf 'edit backend: copy-to-temp, editor, sudo-install-back\n'
  if [[ -n "${AGENT_ARBITER_EDITOR:-}" ]]; then
    printf 'editor: %s\n' "$AGENT_ARBITER_EDITOR"
  elif command -v vim >/dev/null 2>&1; then
    printf 'editor: vim -Nu NONE -n -i NONE --cmd %s\n' "'set t_SI= t_EI= t_SR= t_BE='"
  elif command -v vi >/dev/null 2>&1; then
    printf 'editor: vi\n'
  else
    printf 'editor: none found\n'
  fi
}

install_layout() {
  local force=false
  local install_target=""
  local generated_env
  local current_env
  local backup_file
  local preserved_install_target
  local option

  while (($#)); do
    case "$1" in
      --force)
        force=true
        ;;
      --install-target|--target)
        option="$1"
        shift
        [[ $# -gt 0 ]] || {
          printf 'error: %s requires a value\n' "$option" >&2
          exit 2
        }
        install_target="$1"
        ;;
      --package-version)
        option="$1"
        shift
        [[ $# -gt 0 ]] || {
          printf 'error: %s requires a value\n' "$option" >&2
          exit 2
        }
        install_target="$(package_version_to_install_target "$1")"
        ;;
      *)
        printf 'error: unknown install option: %s\n' "$1" >&2
        exit 2
        ;;
    esac
    shift
  done

  require_source_file "$source_dir/compose.yaml"
  require_source_file "$source_config"

  if sudo test -L "$deploy_dir"; then
    printf 'error: refusing symlink deployment directory: %s\n' "$deploy_dir" >&2
    exit 1
  fi
  sudo install -d -o root -g root -m 0755 "$deploy_dir"
  sudo install -d -o root -g root -m 0755 "$empty_source_dir"
  if sudo test -L "$compose_file"; then
    printf 'error: refusing symlink deployment file: %s\n' "$compose_file" >&2
    exit 1
  fi
  sudo install -o root -g root -m 0444 "$source_dir/compose.yaml" "$compose_file"

  if sudo test -e "$config_file"; then
    require_deploy_file "$config_file"
    if [[ "$force" == true ]]; then
      backup_file="$(backup_deploy_file "$config_file")"
      sudo install -o root -g root -m 0444 "$source_config" "$config_file"
      printf 'replaced config file: %s\n' "$config_file"
      printf 'backup: %s\n' "$backup_file"
    else
      printf 'preserving existing config file: %s\n' "$config_file"
    fi
  else
    sudo install -o root -g root -m 0444 "$source_config" "$config_file"
  fi

  if sudo test -e "$env_file"; then
    require_deploy_file "$env_file"
    if [[ -z "$install_target" ]] && preserved_install_target="$(existing_install_target "$env_file")"; then
      install_target="$preserved_install_target"
    fi
    if [[ "$force" == true ]]; then
      current_env="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-current-env.XXXXXX")"
      generated_env="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-env.XXXXXX")"
      trap 'rm -f "${current_env:-}" "${generated_env:-}"' EXIT
      chmod 0600 "$current_env" "$generated_env"
      sudo install -o "$(id -u)" -g "$(id -g)" -m 0600 "$env_file" "$current_env"
      write_env_template "$config_file" "$generated_env" "$current_env"
      backup_file="$(backup_deploy_file "$env_file")"
      sudo install -o root -g root -m 0600 "$generated_env" "$env_file"
      printf 'regenerated env file from config: %s\n' "$env_file"
      printf 'backup: %s\n' "$backup_file"
      rm -f "$current_env" "$generated_env"
      trap - EXIT
    else
      printf 'preserving existing env file: %s\n' "$env_file"
      printf 'hint: run %s sync-env to add variables required by the installed config.\n' "$0"
    fi
  else
    if [[ -z "$install_target" ]] && preserved_install_target="$(existing_install_target)"; then
      install_target="$preserved_install_target"
    fi
    generated_env="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-env.XXXXXX")"
    trap 'rm -f "${generated_env:-}"' EXIT
    write_env_template "$config_file" "$generated_env"
    sudo install -o root -g root -m 0600 "$generated_env" "$env_file"
    rm -f "$generated_env"
    trap - EXIT
  fi

  if [[ -z "$install_target" ]]; then
    printf 'error: install target required\n' >&2
    printf 'hint: run: %s install --install-target arbiter-suite==0.8.0\n' "$0" >&2
    printf 'hint: or:  %s install --install-target /home/omry/dev/agent-arbiter\n' "$0" >&2
    exit 2
  fi

  if sudo test -e "$install_target_file"; then
    require_deploy_file "$install_target_file"
    if [[ "$force" == true ]]; then
      backup_file="$(backup_deploy_file "$install_target_file")"
      write_install_target_file "$install_target"
      printf 'replaced install target: %s\n' "$install_target_file"
      printf 'backup: %s\n' "$backup_file"
    else
      printf 'preserving existing install target: %s\n' "$install_target_file"
      printf 'hint: run %s install --force --install-target TARGET to replace it.\n' "$0"
    fi
  else
    write_install_target_file "$install_target"
  fi

  protect_files
  if [[ "$0" != "/usr/local/sbin/agent-arbiterctl" ]]; then
    sudo install -o root -g root -m 0755 "$0" /usr/local/sbin/agent-arbiterctl
  fi
}

sync_env_file() {
  local current_env=""
  local generated_env
  local backup_file=""

  require_deploy_file "$config_file"
  if sudo test -L "$env_file"; then
    printf 'error: refusing symlink deployment file: %s\n' "$env_file" >&2
    exit 1
  fi

  generated_env="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-generated-env.XXXXXX")"
  trap 'rm -f "${current_env:-}" "${generated_env:-}"' EXIT
  chmod 0600 "$generated_env"

  if sudo test -f "$env_file"; then
    current_env="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl-current-env.XXXXXX")"
    chmod 0600 "$current_env"
    sudo install -o "$(id -u)" -g "$(id -g)" -m 0600 "$env_file" "$current_env"
    write_env_template "$config_file" "$generated_env" "$current_env"
    backup_file="$env_file.bak.$(date +%Y%m%d%H%M%S)"
    sudo install -o root -g root -m 0600 "$env_file" "$backup_file"
  else
    write_env_template "$config_file" "$generated_env"
  fi

  sudo install -o root -g root -m 0600 "$generated_env" "$env_file"
  rm -f "$current_env" "$generated_env"
  trap - EXIT
  protect_files

  if [[ -n "${backup_file:-}" ]]; then
    printf 'synced env file from config: %s\n' "$env_file"
    printf 'backup: %s\n' "$backup_file"
  else
    printf 'created env file from config: %s\n' "$env_file"
  fi
}

edit_deploy_file() {
  local path="$1"
  local tmp
  require_deploy_file "$path"

  tmp="$(mktemp "${TMPDIR:-/tmp}/agent-arbiterctl.XXXXXX")"
  trap 'rm -f "${tmp:-}"' EXIT
  chmod 0600 "$tmp"
  sudo install -o "$(id -u)" -g "$(id -g)" -m 0600 "$path" "$tmp"

  if ! run_editor "$tmp"; then
    return 1
  fi

  require_deploy_file "$path"
  sudo install -o root -g root -m 0600 "$tmp" "$path"
  rm -f "$tmp"
  trap - EXIT
  protect_files
}

compose() {
  local install_target
  local local_source_dir

  require_deploy_file "$compose_file"
  require_deploy_file "$config_file"
  require_deploy_file "$env_file"
  require_deploy_file "$install_target_file"
  sudo install -d -o root -g root -m 0755 "$empty_source_dir"

  install_target="$(read_install_target_file)"
  if [[ "$install_target" = /* && -d "$install_target" ]]; then
    local_source_dir="$(cd "$install_target" && pwd -P)"
  fi

  cd "$deploy_dir"
  if [[ -n "${local_source_dir:-}" ]]; then
    sudo env AGENT_ARBITER_CONTAINER_INSTALL_TARGET="/source/agent-arbiter" \
      AGENT_ARBITER_LOCAL_SOURCE_DIR="$local_source_dir" \
      docker compose --env-file "$env_file" -f "$compose_file" "$@"
  else
    sudo env AGENT_ARBITER_CONTAINER_INSTALL_TARGET="$install_target" \
      docker compose --env-file "$env_file" -f "$compose_file" "$@"
  fi
}

command="${1:-}"
if (($#)); then
  shift
fi
case "$command" in
  install)
    install_layout "$@"
    ;;
  edit-config)
    edit_deploy_file "$config_file"
    ;;
  edit-env)
    edit_deploy_file "$env_file"
    ;;
  protect)
    require_deploy_file "$compose_file"
    require_deploy_file "$config_file"
    require_deploy_file "$env_file"
    protect_files
    ;;
  sync-env)
    sync_env_file
    ;;
  up)
    compose up -d
    ;;
  restart)
    compose up -d --force-recreate
    ;;
  down)
    compose down
    ;;
  ps)
    compose ps
    ;;
  logs)
    compose logs -f
    ;;
  doctor)
    doctor
    ;;
  "" | -h | --help | help)
    usage
    ;;
  *)
    printf 'error: unknown command: %s\n\n' "$command" >&2
    usage >&2
    exit 2
    ;;
esac
