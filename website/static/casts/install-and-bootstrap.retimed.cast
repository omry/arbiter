[0.054,"o","Heads up: connected to staged Arbiter at https://127.0.0.1:18075.\r\n"]
[0.001,"o","{\r\n  \"plugins\": [\r\n    {\r\n"]
[0.0,"o","      \"id\": \"imap\",\r\n      \"summary\": \"Read and manage mail through configured IMAP accounts.\"\r\n"]
[0.0,"o","    },\r\n    {\r\n"]
[0.0,"o","      \"id\": \"smtp\",\r\n"]
[0.0,"o","      \"summary\": \"Send email through configured SMTP accounts.\"\r\n    }\r\n  ]\r\n}\r\n"]
[0.034,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1marbiter arbiter.url=https://127.0.0.1:18075 plugins smtp account bot | jq .\u001b[0m\r\n"]
