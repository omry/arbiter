[0.081,"o","\r\n\u001b[36;1m# Discover capabilities with the Arbiter client.\u001b[0m\r\n\r\n"]
[0.066,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1marbiter arbiter.url=https://127.0.0.1:18075 plugins | jq ."]
