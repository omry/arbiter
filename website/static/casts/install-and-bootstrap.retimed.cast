[1.253,"o","# @package arbiter.policy.smtp.bot_policy\r\ndefaults:\r\n"]
[0.0,"o","  # Extend the plugin-owned structured schema, then override values below.\r\n"]
[0.0,"o","  - schema@_here_\r\n  - _self_\r\n\r\n# Basic send-rate limits. Use null to disable a limit.\r\nlimits:\r\n  max_messages_per_minute: 30\r\n"]
[0.0,"o","  max_recipients_per_message: 10\r\n\r\n# Dedupe window for repeated send attempts.\r\n"]
[0.0,"o","idempotency:\r\n  expiration_days: 7\r\n  # Optional plugin-relative subdirectory. Defaults to the SMTP plugin's\r\n  # private writable space under idempotency/.\r\n  cache_dir: null\r\n\r\n# Empty lists do not restrict recipients. Add entries to enforce allow/block rules.\r\nrecipient_policy:\r\n"]
[0.0,"o","  allowed_recipients: []\r\n  blocked_recipients: []\r\n  allowed_domain_patterns: []\r\n  blocked_domain_patterns: []\r\n"]
[0.0,"o","\r\n# Save submitted messages to the matching IMAP account's Sent folder when one\r\n# can be resolved. on_failure=warn keeps SMTP success even if IMAP append fails;\r\n# on_failure=fail treats missing sent-copy audit as an operation failure.\r\nsent_copy:\r\n"]
[0.0,"o","  enabled: true\r\n"]
[0.981,"o","\r\n"]
[0.938,"o","\r\n\u001b[36;1m# Edit bot accounts and policies for the local mail lab.\u001b[0m\r\n\r\n"]
[0.9,"o","\u001b[32;1m$\u001b[0m \u001b[1m$EDITOR conf/arbiter/account/imap/bot.yaml conf/arbiter/policy/imap/bot_policy.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1m$EDITOR conf/arbiter/account/smtp/bot.yaml conf/arbiter/policy/smtp/bot_policy.yaml"]
[0.0,"o","\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/imap/bot.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,34p' conf/arbiter/policy/imap/bot_policy.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/smtp/bot.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,30p' conf/arbiter/policy/smtp/bot_policy.yaml\u001b[0m\r\n\r\n"]
[0.088,"o","# @package arbiter.account.imap.bot\r\ndefaults:\r\n- schema@_here_\r\n- _self_\r\n"]
[0.0,"o","description: IMAP account for (${.username})\r\n"]
[0.0,"o","guidance: ''\r\n"]
[0.0,"o","policy: bot_policy\r\n"]
[0.0,"o","host: host.docker.internal\r\nport: 39903\r\n"]
[0.0,"o","username: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\n"]
[0.0,"o","password: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\n"]
[0.0,"o","tls: none\r\n"]
[0.0,"o","verify_peer: false\r\n"]
[0.0,"o","timeout_seconds: 30\r\n"]
[0.0,"o","default_folder: INBOX\r\nfolders:\r\n  INBOX:\r\n"]
[0.0,"o","    description: Local recording inbox.\r\n    kind: INBOX\r\n  Sent:\r\n"]
[0.001,"o","    description: Local recording sent mail.\r\n"]
[0.0,"o","    kind: SENT\r\n  Trash:\r\n"]
[0.0,"o","    description: Local recording trash.\r\n    kind: TRASH\r\n"]
[0.0,"o","# @package arbiter.policy.imap.bot_policy\r\n"]
[0.0,"o","defaults:\r\n"]
[0.0,"o","- schema@_here_\r\n- _self_\r\nfolder_access:\r\n  rules:\r\n"]
[0.0,"o","  - allow_glob: '*'\r\noperation_defaults:\r\n  read: allow\r\n"]
[0.0,"o","  search: allow\r\n  move: true\r\n"]
[0.0,"o","  mark_read: allow\r\n  delete: allow\r\n"]
[0.0,"o","  folder_append: allow\r\n  system_flags:\r\n"]
[0.0,"o","    SEEN: read_write\r\n    FLAGGED: read_write\r\n    ANSWERED: read_write\r\n    DELETED: read_write\r\n    DRAFT: read_write\r\n  user_flags: {}\r\n"]
[0.0,"o","folders: {}\r\n"]
[0.001,"o","# @package arbiter.account.smtp.bot\r\ndefaults:\r\n"]
[0.0,"o","- schema@_here_\r\n"]
[0.0,"o","- _self_\r\ndescription: SMTP account for (${.from_email})\r\nguidance: ''\r\npolicy: bot_policy\r\nhost: host.docker.internal\r\nport: 41863\r\nauthenticate: true\r\n"]
[0.0,"o","username: ${oc.env:SMTP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:SMTP_BOT_ACCOUNT_PASSWORD}\r\nfrom_email: bot@example.test\r\nfrom_name: Arbiter"]
[0.001,"o","\r\n"]
[0.0,"o","tls: none\r\n"]
[0.0,"o","verify_peer: false"]
[0.0,"o","\r\n"]
[0.0,"o","timeout_seconds: 30\r\nsent_copy:\r\n  folder: null\r\n"]
[0.001,"o","# @package arbiter.policy.smtp.bot_policy\r\n"]
[0.0,"o","defaults:\r\n"]
[0.0,"o","- schema@_here_"]
[0.0,"o","\r\n"]
[0.0,"o","- _self_\r\n"]
[0.0,"o","limits:\r\n"]
[0.0,"o","  max_messages_per_minute: null\r\n  max_recipients_per_message: null\r\n"]
[0.0,"o","idempotency:\r\n  expiration_days: 7"]
[0.0,"o","\r\n"]
[0.0,"o","  cache_dir: null\r\n"]
[0.0,"o","recipient_policy:\r\n"]
[0.0,"o","  allowed_recipients: []\r\n"]
[0.0,"o","  blocked_recipients: []\r\n"]
[0.0,"o","  allowed_domain_patterns: []\r\n"]
[0.001,"o","  blocked_domain_patterns: []\r\n"]
[0.0,"o","sent_copy:\r\n"]
[0.0,"o","  enabled: true\r\n  on_failure: warn\r\n"]
