[0.403,"o","# @package arbiter.account.imap.bot\r\ndefaults:\r\n"]
[0.0,"o","  # Extend the plugin-owned structured schema, then override values below.\r\n"]
[0.0,"o","  - schema@_here_\r\n  - _self_\r\n\r\n# Human-facing summary shown by account listing tools.\r\ndescription: IMAP account for (${.username})\r\n\r\n# Operator guidance shown to agents during discovery.\r\nguidance: \"\"\r\n"]
[0.0,"o","\r\n"]
[0.0,"o","# Matching policy generated alongside this account.\r\npolicy: bot_policy\r\n\r\n# IMAP mailbox endpoint.\r\nhost: imap.example.com\r\nport: 993\r\n"]
[0.0,"o","\r\n"]
[0.0,"o","# Credentials are read from the Arbiter process environment.\r\nusername: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\n\r\n# TLS mode: implicit, starttls, or none.\r\ntls: implicit"]
[0.0,"o","\r\n"]
[0.0,"o","verify_peer: true\r\n"]
