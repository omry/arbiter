[0.393,"o","# @package arbiter.policy.smtp.bot_policy\r\ndefaults:\r\n  # Extend the plugin-owned structured schema, then override values below.\r\n"]
[0.0,"o","  - schema@_here_\r\n"]
[0.0,"o","  - _self_\r\n"]
[0.001,"o","\r\n# Basic send-rate limits. Use null to disable a limit.\r\nlimits:\r\n  max_messages_per_minute: 30\r\n"]
[0.0,"o","  max_recipients_per_message: 10\r\n\r\n# Dedupe window for repeated send attempts.\r\nidempotency:\r\n  expiration_days: 7\r\n"]
[0.0,"o","  # Optional plugin-relative subdirectory. Defaults to the SMTP plugin's\r\n"]
[0.0,"o","  # private writable space under idempotency/.\r\n  cache_dir: null\r\n\r\n"]
[0.0,"o","# Empty lists do not restrict recipients. Add entries to enforce allow/block rules.\r\nrecipient_policy:\r\n  allowed_recipients: []\r\n  blocked_recipients: []\r\n  allowed_domain_patterns: []\r\n  blocked_domain_patterns: []\r\n\r\n# Save submitted messages to the matching IMAP account's Sent folder when one\r\n"]
[0.0,"o","# can be resolved. on_failure=warn keeps SMTP success even if IMAP append fails;\r\n# on_failure=fail treats missing sent-copy audit as an operation failure.\r\nsent_copy:\r\n  enabled: true\r\n"]
[0.926,"o","\u001b[32;1m(venv) $\u001b[0m "]
[0.014,"o","\r\n"]
[4.078554,"o","\r\n\u001b[36;1m# Edit bot accounts and policies for the local mail lab.\u001b[0m\r\n\r\n"]
[0.068,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1m$EDITOR conf/arbiter/account/imap/bot.yaml conf/arbiter/policy/imap/bot_policy.yaml"]
[0.0,"o","\u001b[0m\r\n"]
[0.001,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1m"]
[0.0,"o","$EDITOR conf/arbiter/account/smtp/bot.yaml conf/arbiter/policy/smtp/bot_policy.yaml\u001b[0m"]
[0.0,"o","\r\n"]
[0.002,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/imap/bot.yaml\u001b[0m\r\n"]
[0.001,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1msed -n '1,34p' conf/arbiter/policy/imap/bot_policy.yaml\u001b[0m\r\n"]
[0.002,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/smtp/bot.yaml\u001b[0m\r\n"]
[0.001,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1msed -n '1,30p' conf/arbiter/policy/smtp/bot_policy.yaml"]
[0.0,"o","\u001b[0m\r\n"]
[0.0,"o","\r\n"]
[0.075,"o","# @package arbiter.account.imap.bot\r\ndefaults:\r\n- schema@_here_\r\n- _self_\r\ndescription: IMAP account for (${.username})\r\nguidance: ''\r\n"]
[0.001,"o","policy: bot_policy\r\n"]
[0.0,"o","host: host.docker.internal\r\n"]
[0.0,"o","port: 44051\r\nusername: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\ntls: none\r\nverify_peer: false\r\n"]
[0.0,"o","timeout_seconds: 30\r\ndefault_folder: INBOX\r\n"]
[0.0,"o","folders:\r\n  INBOX:\r\n    description: Local recording inbox.\r\n    kind: INBOX\r\n  Sent:\r\n    description: Local recording sent mail.\r\n    kind: SENT\r\n"]
[0.0,"o","  Trash:\r\n    description: Local recording trash.\r\n    kind: TRASH\r\n"]
[0.0,"o","# @package arbiter.policy.imap.bot_policy\r\ndefaults:\r\n- schema@_here_\r\n"]
[0.0,"o","- _self_\r\nfolder_access:\r\n  rules:\r\n"]
[0.0,"o","  - allow_glob: '*'\r\noperation_defaults:\r\n  read: allow\r\n  search: allow\r\n  move: true\r\n"]
[0.001,"o","  mark_read: allow\r\n  delete: allow\r\n  folder_append: allow\r\n  system_flags:\r\n    SEEN: read_write\r\n    FLAGGED: read_write\r\n    ANSWERED: read_write\r\n    DELETED: read_write\r\n    DRAFT: read_write\r\n  user_flags: {}\r\nfolders: {}\r\n"]
[0.0,"o","# @package arbiter.account.smtp.bot\r\ndefaults:\r\n- schema@_here_\r\n- _self_"]
[0.0,"o","\r\n"]
[0.0,"o","description: SMTP account for (${.from_email})\r\nguidance: ''\r\npolicy: bot_policy\r\n"]
[0.0,"o","host: host.docker.internal\r\nport: 57077\r\n"]
[0.0,"o","authenticate: true\r\n"]
[0.0,"o","username: ${oc.env:SMTP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:SMTP_BOT_ACCOUNT_PASSWORD}\r\nfrom_email: bot@example.test\r\nfrom_name: Arbiter\r\ntls: none\r\nverify_peer: false\r\n"]
[0.001,"o","timeout_seconds: 30\r\nsent_copy:\r\n"]
[0.0,"o","  folder: null\r\n"]
[0.0,"o","# @package arbiter.policy.smtp.bot_policy\r\ndefaults:\r\n- schema@_here_\r\n- _self_\r\n"]
[0.0,"o","limits:\r\n  max_messages_per_minute: null\r\n  max_recipients_per_message: null\r\nidempotency:\r\n  expiration_days: 7\r\n"]
[0.0,"o","  cache_dir: null\r\nrecipient_policy:\r\n"]
[0.0,"o","  allowed_recipients: []\r\n"]
[0.0,"o","  blocked_recipients: []\r\n"]
[0.001,"o","  allowed_domain_patterns: []\r\n  blocked_domain_patterns: []\r\n"]
[0.0,"o","sent_copy:\r\n  enabled: true\r\n"]
[0.0,"o","  on_failure: warn\r\n"]
