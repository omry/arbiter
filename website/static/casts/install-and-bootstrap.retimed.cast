[95.978941,"o","Installed Arbiter to /opt/arbiter. Running as arbiter:arbiter\r\nsystemd unit: /etc/systemd/system/arbiter.service\r\nConfig check: passed\r\nServer URL: \u001b[94mhttps://127.0.0.1:8075\u001b[0m\r\n"]
[0.002,"o","[Unit]\r\nDescription=Arbiter Docker service\r\nRequires=docker.service\r\nAfter=docker.service\r\n\r\n[Service]\r\n"]
[0.0,"o","Type=simple\r\nWorkingDirectory=/opt/arbiter\r\n"]
[0.0,"o","ExecStartPre=/bin/sh -c 'i=0; while [ \"$i\" -lt 120 ]; do [ -x \"$1\" ] && \"$1\" info >/dev/null 2>&1 && exit 0; i=$((i + 1)); sleep 1; done; echo \"error: Docker API did not become ready for Arbiter\" >&2; exit 1' arbiter-docker-ready /usr/bin/docker\r\n"]
[0.0,"o","ExecStart=/usr/bin/docker compose --env-file /opt/arbiter/docker.env -f /opt/arbiter/compose.yaml up\r\nExecStop=/usr/bin/docker compose --env-file /opt/arbiter/docker.env -f /opt/arbiter/compose.yaml down\r\nRestart=on-failure\r\nRestartSec=10\r\nTimeoutStartSec=180\r\n\r\n"]
[0.0,"o","[Install]\r\nWantedBy=multi-user.target\r\n"]
[0.001,"o","systemctl cat docker.service\r\nsystemctl daemon-reload\r\nsystemctl enable arbiter.service\r\n"]
