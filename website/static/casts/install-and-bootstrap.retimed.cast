[0.001,"o","{\r\n  \"account\": \"bot\",\r\n  \"config\": {\r\n    \"authenticate\": true,\r\n    \"description\": \"SMTP account for (bot@example.test)\",\r\n    \"from_email\": \"bot@example.test\",\r\n    \"from_name\": \"Arbiter\",\r\n    \"guidance\": \"\",\r\n    \"host\": \"host.docker.internal\",\r\n    \"password\": \"<redacted>\",\r\n    \"policy\": \"bot_policy\",\r\n    \"port\": 57077,\r\n    \"sent_copy\": {\r\n"]
[0.0,"o","      \"folder\": null\r\n    },\r\n    \"timeout_seconds\": 30,\r\n    \"tls\": \"none\",\r\n    \"username\": \"bot@example.test\",\r\n    \"verify_peer\": false\r\n  },\r\n  \"description\": \"SMTP account for (bot@example.test)\",\r\n"]
[0.0,"o","  \"guidance\": \"\",\r\n"]
[0.0,"o","  \"kind\": \"account\","]
[0.0,"o","\r\n"]
[0.0,"o","  \"plugin\": \"smtp\",\r\n  \"policy\": {\r\n"]
[0.0,"o","    \"kind\": \"policy\",\r\n    \"plugin\": \"smtp\",\r\n    \"policy\": \"bot_policy\",\r\n    \"rules\": {\r\n      \"idempotency\": {\r\n        \"cache_dir\": \"<redacted>\",\r\n        \"expiration_days\": 7\r\n"]
[0.0,"o","      },\r\n"]
[0.0,"o","      \"limits\": {\r\n        \"max_messages_per_minute\": null,\r\n        \"max_recipients_per_message\": null\r\n      },\r\n      \"recipient_policy\": {\r\n"]
[0.0,"o","        \"allowed_domain_patterns\": [],\r\n        \"allowed_recipients\": [],\r\n        \"blocked_domain_patterns\": [],\r\n        \"blocked_recipients\": []\r\n      },\r\n      \"sent_copy\": {\r\n        \"enabled\": true,\r\n        \"on_failure\": \"warn\"\r\n      }\r\n    }\r\n  }\r\n}\r\n"]
