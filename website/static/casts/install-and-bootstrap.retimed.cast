[0.074,"o","\r\n\u001b[36;1m# Send a test message from the bot to itself.\u001b[0m\r\n\r\n"]
[0.063,"o","\u001b[32;1m(venv) $\u001b[0m \u001b[1marbiter arbiter.url=https://127.0.0.1:18075 op run smtp:send_email --args '{\"account\":\"bot\",\"to\":[\"bot@example.test\"],\"subject\":\"Arbiter install smoke test\",\"text_body\":\"Hello from Arbiter staging.\",\"idempotency_key\":\"install-smoke-1\"}' | jq .\u001b[0m\r\n"]
