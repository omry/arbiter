[3.032229,"o","# @package arbiter.account.imap.bot\r\ndefaults:\r\n"]
[0.0,"o","  # Extend the plugin-owned structured schema, then override values below.\r\n"]
[0.0,"o","  - schema@_here_\r\n  - _self_\r\n\r\n# Human-facing summary shown by account listing tools.\r\ndescription: IMAP account for (${.username})\r\n"]
[0.0,"o","\r\n# Operator guidance shown to agents during discovery.\r\nguidance: \"\""]
[0.0,"o","\r\n"]
[0.0,"o","\r\n# Matching policy generated alongside this account.\r\n"]
[0.0,"o","policy: bot_policy\r\n\r\n# IMAP mailbox endpoint.\r\n"]
[0.0,"o","host: imap.example.com\r\nport: 993"]
[0.0,"o","\r\n\r\n"]
[0.0,"o","# Credentials are read from the Arbiter process environment.\r\nusername: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\n\r\n"]
[0.0,"o","# TLS mode: implicit, starttls, or none.\r\ntls: implicit\r\n"]
[0.0,"o","verify_peer: true\r\n"]
[0.038,"o","\u001b[32;1m$\u001b[0m \u001b[1m"]
[0.0,"o","sed -n '1,34p' conf/arbiter/policy/imap/bot_policy.yaml"]
[0.0,"o","\u001b[0m\r\n"]
[0.049,"o","# @package arbiter.policy.imap.bot_policy\r\ndefaults:\r\n  # Extend the plugin-owned structured schema, then override values below.\r\n  - schema@_here_\r\n  - _self_\r\n\r\n# Explicit folder access baseline. This default-open variant exposes all server folders first, then lets you add deny rules below.\r\nfolder_access:\r\n  rules:\r\n    - allow_glob: \"*\"\r\noperation_defaults:\r\n  read: allow\r\n  search: allow\r\n"]
[0.0,"o","  move: false\r\n"]
[0.0,"o","  mark_read: deny\r\n  delete: deny\r\n  folder_append: deny\r\n  system_flags:\r\n    SEEN: read_only\r\n    FLAGGED: read_only\r\n    ANSWERED: read_only\r\n    DELETED: read_only\r\n"]
[0.0,"o","    DRAFT: read_only\r\n"]
[0.0,"o","  user_flags: {}\r\n\r\nfolders:\r\n  Sent:\r\n    folder_append: allow\r\n    system_flags:\r\n      SEEN: read_write\r\n  Drafts:\r\n    folder_append: allow\r\n"]
[0.0,"o","    system_flags:\r\n      SEEN: read_write\r\n"]
[0.037,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/smtp/bot.yaml\u001b[0m\r\n"]
[0.051,"o","# @package arbiter.account.smtp.bot\r\n"]
[0.0,"o","defaults:\r\n"]
[0.0,"o","  # Extend the plugin-owned structured schema, then override values below.\r\n  - schema@_here_\r\n"]
[0.0,"o","  - _self_\r\n\r\n# Human-facing summary shown by account listing tools.\r\ndescription: SMTP account for (${.from_email})\r\n\r\n# Operator guidance shown to agents during discovery.\r\nguidance: \"\""]
[0.0,"o","\r\n\r\n# Matching policy generated alongside this account.\r\npolicy: bot_policy\r\n\r\n# SMTP submission endpoint.\r\n"]
[0.0,"o","host: smtp.example.com\r\nport: 587\r\n\r\n# Set to false for unauthenticated local relays.\r\nauthenticate: true\r\n\r\n# Credentials are read from the Arbiter process environment.\r\nusername: ${oc.env:SMTP_BOT_ACCOUNT_USERNAME}\r\n"]
[0.0,"o","password: ${oc.env:SMTP_BOT_ACCOUNT_PASSWORD}\r\n\r\n"]
[0.036,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,30p' conf/arbiter/policy/smtp/bot_policy.yaml\u001b[0m\r\n"]
[0.05,"o","# @package arbiter.policy.smtp.bot_policy\r\ndefaults:\r\n"]
[0.0,"o","  # Extend the plugin-owned structured schema, then override values below.\r\n"]
[0.0,"o","  - schema@_here_\r\n"]
[0.001,"o","  - _self_\r\n\r\n"]
[0.0,"o","# Basic send-rate limits. Use null to disable a limit.\r\n"]
[0.0,"o","limits:\r\n  max_messages_per_minute: 30\r\n  max_recipients_per_message: 10\r\n\r\n# Dedupe window for repeated send attempts.\r\n"]
[0.0,"o","idempotency:\r\n  expiration_days: 7\r\n  # Optional plugin-relative subdirectory. Defaults to the SMTP plugin's\r\n  # private writable space under idempotency/.\r\n  cache_dir: null\r\n"]
[0.0,"o","\r\n# Empty lists do not restrict recipients. Add entries to enforce allow/block rules.\r\nrecipient_policy:\r\n  allowed_recipients: []\r\n  blocked_recipients: []\r\n  allowed_domain_patterns: []\r\n  blocked_domain_patterns: []\r\n\r\n# Save submitted messages to the matching IMAP account's Sent folder when one\r\n# can be resolved. on_failure=warn keeps SMTP success even if IMAP append fails;\r\n# on_failure=fail treats missing sent-copy audit as an operation failure.\r\nsent_copy:\r\n  enabled: true\r\n"]
[0.951,"o","\r\n"]
[0.083,"o","\r\n\u001b[36;1m# Edit bot accounts and policies for the local mail lab.\u001b[0m\r\n\r\n"]
[0.05,"o","\u001b[32;1m$\u001b[0m \u001b[1m$EDITOR conf/arbiter/account/imap/bot.yaml conf/arbiter/policy/imap/bot_policy.yaml\u001b[0m\r\n\u001b[32;1m$\u001b[0m \u001b[1m$EDITOR conf/arbiter/account/smtp/bot.yaml conf/arbiter/policy/smtp/bot_policy.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/imap/bot.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,34p' conf/arbiter/policy/imap/bot_policy.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,26p' conf/arbiter/account/smtp/bot.yaml\u001b[0m\r\n"]
[0.0,"o","\u001b[32;1m$\u001b[0m \u001b[1msed -n '1,30p' conf/arbiter/policy/smtp/bot_policy.yaml\u001b[0m\r\n"]
[0.0,"o","\r\n"]
[0.934,"o","# @package arbiter.account.imap.bot\r\ndefaults:"]
[0.0,"o","\r\n"]
[0.0,"o","- schema@_here_\r\n"]
[0.0,"o","- _self_\r\ndescription: IMAP account for (${.username})\r\n"]
[0.0,"o","guidance: ''\r\npolicy: bot_policy\r\n"]
[0.0,"o","host: host.docker.internal\r\nport: 42319\r\nusername: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\npassword: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\ntls: none\r\nverify_peer: false\r\ntimeout_seconds: 30\r\ndefault_folder: INBOX\r\nfolders:"]
[0.0,"o","\r\n"]
[0.0,"o","  INBOX:\r\n    description: Local recording inbox.\r\n"]
[0.0,"o","    kind: INBOX\r\n  Sent:\r\n"]
[0.0,"o","    description: Local recording sent mail.\r\n"]
[0.0,"o","    kind: SENT\r\n"]
[0.0,"o","  Trash:\r\n    description: Local recording trash.\r\n"]
[0.0,"o","    kind: TRASH"]
[0.0,"o","\r\n"]
[0.002,"o","# @package arbiter.policy.imap.bot_policy\r\ndefaults:\r\n- schema@_here_\r\n- _self_\r\nfolder_access:\r\n  rules:\r\n  - allow_glob: '*'\r\noperation_defaults:\r\n  read: allow\r\n  search: allow\r\n  move: true\r\n  mark_read: allow\r\n  delete: allow\r\n  folder_append: allow\r\n  system_flags:\r\n    SEEN: read_write\r\n    FLAGGED: read_write\r\n"]
[0.0,"o","    ANSWERED: read_write\r\n    DELETED: read_write\r\n    DRAFT: read_write\r\n  user_flags: {}\r\nfolders: {}\r\n"]
[0.001,"o","# @package arbiter.account.smtp.bot\r\ndefaults:\r\n- schema@_here_\r\n- _self_\r\ndescription: SMTP account for (${.from_email})\r\nguidance: ''\r\npolicy: bot_policy\r\nhost: host.docker.internal\r\nport: 55831\r\n"]
[0.0,"o","authenticate: true\r\nusername: ${oc.env:SMTP_BOT_ACCOUNT_USERNAME}\r\n"]
[0.0,"o","password: ${oc.env:SMTP_BOT_ACCOUNT_PASSWORD}\r\nfrom_email: bot@example.test\r\n"]
