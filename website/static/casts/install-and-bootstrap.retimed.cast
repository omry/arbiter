[1.258,"o","# @package arbiter.account.imap.bot\r\ndefaults:\r\n  # Extend the plugin-owned structured schema, then override values below.\r\n  - schema@_here_\r\n  - _self_"]
[0.0,"o","\r\n"]
[0.0,"o","\r\n# Human-facing summary shown by account listing tools.\r\n"]
[0.0,"o","description: IMAP account for (${.username})\r\n\r\n"]
[0.0,"o","# Operator guidance shown to agents during discovery.\r\n"]
[0.0,"o","guidance: \"\"\r\n"]
[0.0,"o","\r\n# Matching policy generated alongside this account.\r\n"]
[0.001,"o","policy: bot_policy\r\n\r\n"]
[0.0,"o","# IMAP mailbox endpoint.\r\nhost: imap.example.com\r\n"]
[0.0,"o","port: 993\r\n\r\n"]
[0.0,"o","# Credentials are read from the Arbiter process environment.\r\nusername: ${oc.env:IMAP_BOT_ACCOUNT_USERNAME}\r\n"]
[0.0,"o","password: ${oc.env:IMAP_BOT_ACCOUNT_PASSWORD}\r\n\r\n"]
[0.0,"o","# TLS mode: implicit, starttls, or none.\r\n"]
[0.0,"o","tls: implicit\r\n"]
[0.0,"o","verify_peer: true\r\n"]
