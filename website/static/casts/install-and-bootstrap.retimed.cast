[0.403,"o","# @package arbiter.policy.imap.bot_policy\r\ndefaults:\r\n  # Extend the plugin-owned structured schema, then override values below.\r\n  - schema@_here_\r\n  - _self_\r\n\r\n"]
[0.0,"o","# Explicit folder access baseline. This default-open variant exposes all server folders first, then lets you add deny rules below.\r\n"]
[0.0,"o","folder_access:\r\n  rules:\r\n    - allow_glob: \"*\"\r\noperation_defaults:\r\n"]
[0.0,"o","  read: allow\r\n  search: allow\r\n  move: false\r\n  mark_read: deny\r\n  delete: deny"]
[0.0,"o","\r\n  folder_append: deny\r\n  system_flags:\r\n"]
[0.0,"o","    SEEN: read_only\r\n    FLAGGED: read_only\r\n"]
[0.0,"o","    ANSWERED: read_only\r\n"]
[0.0,"o","    DELETED: read_only\r\n"]
[0.0,"o","    DRAFT: read_only\r\n  user_flags: {}\r\n"]
[0.0,"o","\r\nfolders:\r\n  Sent:\r\n    folder_append: allow\r\n"]
[0.0,"o","    system_flags:\r\n      SEEN: read_write\r\n  Drafts:\r\n    folder_append: allow\r\n    system_flags:\r\n      SEEN: read_write\r\n"]
