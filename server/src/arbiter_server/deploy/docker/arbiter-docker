    -v "$target_requirements_file:/requirements.txt:ro"
    -v "$target_wheels_dir:/wheels:ro"
    "$image"
    python -m pip --disable-pip-version-check install --no-cache-dir
    --target /tmp/arbiter-wheelhouse-check
