#!/usr/bin/env python3
from __future__ import annotations

import argparse
import base64
import csv
import hashlib
import io
import shutil
import sys
import zipfile
from pathlib import Path


PACKAGE_NAME = "arbiter-skill"
CONFIG_FILE_NAME = "agent-skill-installer.yaml"
WHEEL_TAG = "py3-none-any"


def distribution_name(package_name: str) -> str:
    return package_name.replace("-", "_")


def import_name(package_name: str) -> str:
    return distribution_name(package_name)


def display_path(path: Path, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def server_version(root: Path) -> str:
    in_project = False
    for line in (
        (root / "server" / "pyproject.toml").read_text(encoding="utf-8").splitlines()
    ):
        stripped = line.strip()
        if stripped == "[project]":
            in_project = True
            continue
        if in_project and stripped.startswith("["):
            break
        if in_project and stripped.startswith("version"):
            _name, _separator, value = stripped.partition("=")
            version = value.strip().strip('"')
            if version:
                return version
    raise ValueError("missing project.version in server/pyproject.toml")


def installer_config(root: Path) -> bytes:
    return (root / "skill" / CONFIG_FILE_NAME).read_bytes()


def skill_text(root: Path) -> bytes:
    return (root / "skill" / "SKILL.md").read_bytes()


def stage_skill_local(*, root: Path, local_root: Path) -> Path:
    skill = local_root / PACKAGE_NAME
    skill.mkdir(parents=True, exist_ok=True)
    (skill / "SKILL.md").write_bytes(skill_text(root))
    (skill / CONFIG_FILE_NAME).write_bytes(installer_config(root))
    return skill


def metadata(package_name: str, version: str, summary: str) -> bytes:
    return (
        "Metadata-Version: 2.1\n"
        f"Name: {package_name}\n"
        f"Version: {version}\n"
        f"Summary: {summary}\n"
        "Requires-Python: >=3.10\n"
    ).encode("utf-8")


def wheel_file() -> bytes:
    return (
        "Wheel-Version: 1.0\n"
        "Generator: arbiter package_arbiter_skill\n"
        "Root-Is-Purelib: true\n"
        f"Tag: {WHEEL_TAG}\n"
    ).encode("utf-8")


def record_hash(data: bytes) -> str:
    digest = hashlib.sha256(data).digest()
    encoded = base64.urlsafe_b64encode(digest).rstrip(b"=").decode("ascii")
    return f"sha256={encoded}"


def zip_info(name: str, mode: int) -> zipfile.ZipInfo:
    info = zipfile.ZipInfo(name)
    info.compress_type = zipfile.ZIP_DEFLATED
    info.external_attr = (mode & 0xFFFF) << 16
    return info


def write_wheel(
    *,
    output: Path,
    package_name: str,
    version: str,
    files: dict[str, tuple[bytes, int]],
) -> Path:
    dist_name = distribution_name(package_name)
    dist_info = f"{dist_name}-{version}.dist-info"
    wheel_files = dict(files)
    wheel_files[f"{dist_info}/WHEEL"] = (wheel_file(), 0o644)
    wheel_files[f"{dist_info}/METADATA"] = (
        metadata(package_name, version, f"Arbiter agent skill package {package_name}."),
        0o644,
    )

    rows: list[list[str]] = []
    output.parent.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(output, "w") as archive:
        for name in sorted(wheel_files):
            data, mode = wheel_files[name]
            archive.writestr(zip_info(name, mode), data)
            rows.append([name, record_hash(data), str(len(data))])

        record_name = f"{dist_info}/RECORD"
        rows.append([record_name, "", ""])
        record_text = io.StringIO()
        writer = csv.writer(record_text, lineterminator="\n")
        writer.writerows(rows)
        archive.writestr(zip_info(record_name, 0o644), record_text.getvalue())
    return output


def skill_wheel(*, root: Path, wheels_root: Path, version: str) -> Path:
    module = import_name(PACKAGE_NAME)
    return write_wheel(
        output=wheels_root
        / f"{distribution_name(PACKAGE_NAME)}-{version}-{WHEEL_TAG}.whl",
        package_name=PACKAGE_NAME,
        version=version,
        files={
            f"{module}/__init__.py": (f'__version__ = "{version}"\n'.encode(), 0o644),
            f"{module}/_skill/SKILL.md": (skill_text(root), 0o644),
            f"{module}/_skill/{CONFIG_FILE_NAME}": (installer_config(root), 0o644),
        },
    )


def package_skill(
    *,
    root: Path,
    outdir: Path,
    formats: set[str],
    clean: bool,
) -> list[Path]:
    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    version = server_version(root)
    written: list[Path] = []

    if "local" in formats:
        written.append(stage_skill_local(root=root, local_root=outdir / "local"))

    if "wheel" in formats:
        written.append(
            skill_wheel(root=root, wheels_root=outdir / "wheels", version=version)
        )

    for path in written:
        print(f"packaged {display_path(path, root)}")
    return written


def parse_formats(value: str) -> set[str]:
    if value == "all":
        return {"local", "wheel"}
    return {value}


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Package the Arbiter agent skill.")
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument(
        "--outdir",
        default="dist/arbiter-skill",
        help="output directory, default: dist/arbiter-skill",
    )
    parser.add_argument(
        "--format",
        choices=("all", "local", "wheel"),
        default="all",
        help="artifact format to emit, default: all",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before packaging",
    )
    namespace = parser.parse_args(argv)

    root = Path(namespace.root).resolve()
    outdir = Path(namespace.outdir)
    if not outdir.is_absolute():
        outdir = root / outdir

    try:
        package_skill(
            root=root,
            outdir=outdir,
            formats=parse_formats(namespace.format),
            clean=namespace.clean,
        )
    except (OSError, ValueError) as exc:
        print(f"package_arbiter_skill: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
