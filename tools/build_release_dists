#!/usr/bin/env python3
from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


@dataclass(frozen=True)
class Package:
    key: str
    name: str
    path: Path | None
    kind: str = "python"


PACKAGES = (
    Package(key="core", name="arbiter-core", path=Path("core")),
    Package(key="imap", name="arbiter-imap", path=Path("imap")),
    Package(key="smtp", name="arbiter-smtp", path=Path("smtp")),
    Package(key="meta:all", name="arbiter-suite", path=Path("meta/arbiter-suite")),
    Package(key="skill", name="arbiter-skill", path=None, kind="skill"),
    Package(
        key="skill:linux-amd64",
        name="arbiter-skill-linux-amd64",
        path=None,
        kind="skill",
    ),
    Package(
        key="skill:linux-arm64",
        name="arbiter-skill-linux-arm64",
        path=None,
        kind="skill",
    ),
    Package(
        key="skill:darwin-amd64",
        name="arbiter-skill-darwin-amd64",
        path=None,
        kind="skill",
    ),
    Package(
        key="skill:darwin-arm64",
        name="arbiter-skill-darwin-arm64",
        path=None,
        kind="skill",
    ),
    Package(
        key="skill:windows-amd64",
        name="arbiter-skill-windows-amd64",
        path=None,
        kind="skill",
    ),
    Package(
        key="skill:windows-arm64",
        name="arbiter-skill-windows-arm64",
        path=None,
        kind="skill",
    ),
)
PACKAGE_BY_KEY = {package.key: package for package in PACKAGES}
PACKAGE_KEYS = tuple(PACKAGE_BY_KEY)


def _parse_package_keys(value: str) -> tuple[Package, ...]:
    value = value.strip()
    if value == "all":
        return PACKAGES

    keys = tuple(dict.fromkeys(key.strip() for key in value.split(",") if key.strip()))
    if not keys:
        raise ValueError("--packages must be 'all' or a comma-separated key list")
    if "all" in keys:
        raise ValueError("--packages cannot combine 'all' with package keys")

    unknown = sorted(set(keys) - set(PACKAGE_KEYS))
    if unknown:
        expected = ", ".join(("all", *PACKAGE_KEYS))
        raise ValueError(
            f"unknown package key in --packages: {', '.join(unknown)} "
            f"(expected one or more of: {expected})"
        )
    return tuple(PACKAGE_BY_KEY[key] for key in keys)


def _run(
    command: list[str],
    *,
    verbose: bool,
) -> None:
    if verbose:
        subprocess.run(command, check=True)
        return

    result = subprocess.run(
        command,
        check=False,
        text=True,
        capture_output=True,
    )
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        raise subprocess.CalledProcessError(result.returncode, command)


def _distribution_name(package_name: str) -> str:
    return package_name.replace("-", "_")


def _copy_skill_wheels(
    *,
    source_dir: Path,
    outdir: Path,
    packages: tuple[Package, ...],
) -> None:
    selected_distributions = {
        _distribution_name(package.name)
        for package in packages
        if package.kind == "skill"
    }
    for wheel in sorted((source_dir / "wheels").glob("arbiter_skill*.whl")):
        distribution = wheel.name.split("-", 1)[0]
        if distribution not in selected_distributions:
            continue
        target = outdir / wheel.name
        shutil.copy2(wheel, target)
        print(f"build: {target.name}")


def _build_skill_distributions(
    *,
    root: Path,
    outdir: Path,
    packages: tuple[Package, ...],
    verbose: bool,
) -> None:
    with tempfile.TemporaryDirectory(
        prefix="arbiter-skill-release-", dir=outdir.parent
    ) as tmp:
        skill_outdir = Path(tmp)
        print("build: arbiter Go client binaries")
        _run(
            [str(root / "tools" / "build_go_client"), "--root", str(root), "--clean"],
            verbose=verbose,
        )
        print("build: arbiter skill wheels")
        _run(
            [
                str(root / "tools" / "package_arbiter_skill"),
                "--root",
                str(root),
                "--clean",
                "--format",
                "wheel",
                "--outdir",
                str(skill_outdir),
            ],
            verbose=verbose,
        )
        _copy_skill_wheels(source_dir=skill_outdir, outdir=outdir, packages=packages)


def build_distributions(
    *,
    root: Path,
    outdir: Path,
    clean: bool,
    packages: tuple[Package, ...],
    verbose: bool,
) -> None:
    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    python_packages = tuple(package for package in packages if package.kind == "python")
    skill_selected = any(package.kind == "skill" for package in packages)

    for package in python_packages:
        assert package.path is not None
        print(f"build: {package.name}")
        command = [
            sys.executable,
            "-m",
            "build",
            "--sdist",
            "--wheel",
            "--outdir",
            str(outdir),
            str(root / package.path),
        ]
        _run(command, verbose=verbose)

    if skill_selected:
        _build_skill_distributions(
            root=root,
            outdir=outdir,
            packages=packages,
            verbose=verbose,
        )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Build Arbiter release distributions.")
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument(
        "--outdir",
        default="dist",
        help="directory for built distributions, default: dist",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before building",
    )
    parser.add_argument(
        "--packages",
        default="all",
        metavar="KEYS",
        help=(
            "limit builds to 'all' or comma-separated package keys "
            f"({', '.join(PACKAGE_KEYS)})"
        ),
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="show detailed output from python -m build",
    )
    namespace = parser.parse_args(argv)

    try:
        packages = _parse_package_keys(namespace.packages)
        build_distributions(
            root=Path(namespace.root).resolve(),
            outdir=Path(namespace.outdir).resolve(),
            clean=namespace.clean,
            packages=packages,
            verbose=namespace.verbose,
        )
    except (OSError, subprocess.CalledProcessError, ValueError) as exc:
        print(f"build_release_dists: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
