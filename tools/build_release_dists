#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from release_packages import (  # noqa: E402
    CLIENT_TARGETS,
    Package,
    package_by_key,
    package_keys,
    release_packages,
)


def _parse_package_keys(value: str, *, root: Path | None = None) -> tuple[Package, ...]:
    value = value.strip()
    root = root or Path.cwd()
    if value == "all":
        return release_packages(root)

    known_keys = package_keys(root)
    packages_by_key = package_by_key(root)
    keys = tuple(dict.fromkeys(key.strip() for key in value.split(",") if key.strip()))
    if not keys:
        raise ValueError("--packages must be 'all' or a comma-separated key list")
    if "all" in keys:
        raise ValueError("--packages cannot combine 'all' with package keys")

    unknown = sorted(set(keys) - set(known_keys))
    if unknown:
        expected = ", ".join(("all", *known_keys))
        raise ValueError(
            f"unknown package key in --packages: {', '.join(unknown)} "
            f"(expected one or more of: {expected})"
        )
    return tuple(packages_by_key[key] for key in keys)


def _run(
    command: list[str],
    *,
    verbose: bool,
    env: dict[str, str] | None = None,
) -> None:
    if verbose:
        subprocess.run(command, check=True, env=env)
        return

    result = subprocess.run(
        command,
        check=False,
        text=True,
        capture_output=True,
        env=env,
    )
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        raise subprocess.CalledProcessError(result.returncode, command)


def _distribution_name(package_name: str) -> str:
    return package_name.replace("-", "_")


def _server_version(root: Path) -> str:
    in_project = False
    for line in (root / "server" / "pyproject.toml").read_text().splitlines():
        stripped = line.strip()
        if stripped == "[project]":
            in_project = True
            continue
        if in_project and stripped.startswith("["):
            break
        if in_project and stripped.startswith("version"):
            _name, _separator, value = stripped.partition("=")
            version = value.strip().strip('"')
            if version:
                return version
    raise ValueError("missing project.version in server/pyproject.toml")


def _build_go_client(*, root: Path, verbose: bool) -> None:
    print("build: arbiter Go client binaries")
    _run(
        [str(root / "tools" / "build_go_client"), "--root", str(root), "--clean"],
        verbose=verbose,
    )


def _copy_skill_wheels(
    *,
    source_dir: Path,
    outdir: Path,
    packages: tuple[Package, ...],
) -> None:
    selected_distributions = {
        _distribution_name(package.name)
        for package in packages
        if package.kind == "skill"
    }
    for wheel in sorted((source_dir / "wheels").glob("arbiter_skill*.whl")):
        distribution = wheel.name.split("-", 1)[0]
        if distribution not in selected_distributions:
            continue
        target = outdir / wheel.name
        shutil.copy2(wheel, target)
        print(f"build: {target.name}")


def _build_skill_distributions(
    *,
    root: Path,
    outdir: Path,
    packages: tuple[Package, ...],
    verbose: bool,
) -> None:
    with tempfile.TemporaryDirectory(
        prefix="arbiter-skill-release-", dir=outdir.parent
    ) as tmp:
        skill_outdir = Path(tmp)
        print("build: arbiter skill wheels")
        _run(
            [
                str(root / "tools" / "package_arbiter_skill"),
                "--root",
                str(root),
                "--clean",
                "--format",
                "wheel",
                "--outdir",
                str(skill_outdir),
            ],
            verbose=verbose,
        )
        _copy_skill_wheels(source_dir=skill_outdir, outdir=outdir, packages=packages)


def _build_client_distributions(
    *,
    root: Path,
    outdir: Path,
    verbose: bool,
) -> None:
    version = _server_version(root)
    client_root = root / "client"
    for target in CLIENT_TARGETS:
        print(f"build: arbiter-client {target} wheel")
        env = os.environ.copy()
        env.update(
            {
                "ARBITER_CLIENT_VERSION": version,
                "ARBITER_CLIENT_TARGET": target,
            }
        )
        _run(
            [
                sys.executable,
                "-m",
                "build",
                "--wheel",
                "--outdir",
                str(outdir),
                str(client_root),
            ],
            verbose=verbose,
            env=env,
        )


def build_distributions(
    *,
    root: Path,
    outdir: Path,
    clean: bool,
    packages: tuple[Package, ...],
    verbose: bool,
) -> None:
    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    python_packages = tuple(
        package for package in packages if package.kind in {"server", "plugin", "meta"}
    )
    client_selected = any(package.kind == "client" for package in packages)
    skill_selected = any(package.kind == "skill" for package in packages)

    for package in python_packages:
        assert package.path is not None
        print(f"build: {package.name}")
        command = [
            sys.executable,
            "-m",
            "build",
            "--sdist",
            "--wheel",
            "--outdir",
            str(outdir),
            str(root / package.path),
        ]
        _run(command, verbose=verbose)

    if client_selected or skill_selected:
        _build_go_client(root=root, verbose=verbose)

    if client_selected:
        _build_client_distributions(root=root, outdir=outdir, verbose=verbose)

    if skill_selected:
        _build_skill_distributions(
            root=root,
            outdir=outdir,
            packages=packages,
            verbose=verbose,
        )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Build Arbiter release distributions.")
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument(
        "--outdir",
        default="dist",
        help="directory for built distributions, default: dist",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before building",
    )
    parser.add_argument(
        "--packages",
        default="all",
        metavar="KEYS",
        help=(
            "limit builds to 'all' or comma-separated package keys "
            "(run with an invalid key to see the currently discovered keys)"
        ),
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="show detailed output from python -m build",
    )
    namespace = parser.parse_args(argv)

    try:
        root = Path(namespace.root).resolve()
        packages = _parse_package_keys(namespace.packages, root=root)
        build_distributions(
            root=root,
            outdir=Path(namespace.outdir).resolve(),
            clean=namespace.clean,
            packages=packages,
            verbose=namespace.verbose,
        )
    except (OSError, subprocess.CalledProcessError, ValueError) as exc:
        print(f"build_release_dists: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
