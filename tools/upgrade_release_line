#!/usr/bin/env python3
from __future__ import annotations

import argparse
import difflib
import re
import sys
from dataclasses import dataclass
from functools import total_ordering
from pathlib import Path
from typing import TextIO

sys.path.insert(0, str(Path(__file__).resolve().parent))

from release_packages import plugin_packages  # noqa: E402


SUITE_PYPROJECT = Path("meta/arbiter-suite/pyproject.toml")
SKILL_PYPROJECT = Path("skill/pyproject.toml")
DOC_FILES = (
    Path("website/docs/operate/deployment/3-bundle-deep-dive.md"),
    Path("website/docs/operate/server-reference.md"),
    Path("website/docs/extend/plugins.md"),
)
DOC_EXPECTATIONS = {
    Path("website/docs/operate/deployment/3-bundle-deep-dive.md"): (
        "arbiter-suite=={final_version}",
        "arbiter-server=={version}",
        "arbiter-smtp=={version}",
        "/wheels/arbiter_server-{version}-py3-none-any.whl",
        "/wheels/arbiter_smtp-{version}-py3-none-any.whl",
        "{dev_version}",
    ),
    Path("website/docs/operate/server-reference.md"): ("arbiter-server=={version}",),
    Path("website/docs/extend/plugins.md"): (
        "`{line}.x`",
        "`{line}` line",
        "`{final_version}`",
        "`{line}.1`",
        'server_api_version = "{line}"',
        '"arbiter-server>={final_version},<{next_version}"',
    ),
}
GREEN = "\033[32m"
RED = "\033[31m"
RESET = "\033[0m"


@dataclass(frozen=True, order=True)
class ReleaseLine:
    major: int
    minor: int

    @classmethod
    def parse(cls, value: str) -> "ReleaseLine":
        match = re.fullmatch(r"(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)", value)
        if match is None:
            raise ValueError("release line must be MAJOR.MINOR, for example 0.9")
        return cls(major=int(match.group(1)), minor=int(match.group(2)))

    @property
    def text(self) -> str:
        return f"{self.major}.{self.minor}"

    @property
    def version(self) -> str:
        return f"{self.text}.0"

    @property
    def next_version(self) -> str:
        return f"{self.major}.{self.minor + 1}.0"


@total_ordering
@dataclass(frozen=True)
class PackageVersion:
    major: int
    minor: int
    patch: int
    dev: int | None = None

    @classmethod
    def parse(cls, value: str) -> "PackageVersion":
        match = re.fullmatch(
            r"([0-9]+)\.([0-9]+)\.([0-9]+)(?:[.-]dev([0-9]+))?",
            value,
        )
        if match is None:
            raise ValueError(f"invalid package version: {value}")
        return cls(
            major=int(match.group(1)),
            minor=int(match.group(2)),
            patch=int(match.group(3)),
            dev=int(match.group(4)) if match.group(4) is not None else None,
        )

    @classmethod
    def final_for_line(cls, line: ReleaseLine) -> "PackageVersion":
        return cls(major=line.major, minor=line.minor, patch=0)

    @property
    def line(self) -> ReleaseLine:
        return ReleaseLine(major=self.major, minor=self.minor)

    @property
    def text(self) -> str:
        version = f"{self.major}.{self.minor}.{self.patch}"
        if self.dev is not None:
            version = f"{version}.dev{self.dev}"
        return version

    def _sort_key(self) -> tuple[int, int, int, int, int]:
        return (
            self.major,
            self.minor,
            self.patch,
            1 if self.dev is None else 0,
            self.dev or 0,
        )

    def __lt__(self, other: object) -> bool:
        if not isinstance(other, PackageVersion):
            return NotImplemented
        return self._sort_key() < other._sort_key()


@dataclass(frozen=True)
class Change:
    path: Path
    before: str
    after: str


def _read(root: Path, path: Path) -> str:
    full_path = root / path
    if not full_path.exists():
        raise FileNotFoundError(f"expected release file is missing: {path}")
    return full_path.read_text(encoding="utf-8")


def _plugin_package_files(root: Path) -> tuple[Path, ...]:
    return tuple(
        package.path / "pyproject.toml"
        for package in plugin_packages(root)
        if package.path is not None
    )


def _package_files(root: Path) -> tuple[Path, ...]:
    return (
        SUITE_PYPROJECT,
        Path("server/pyproject.toml"),
        SKILL_PYPROJECT,
        *_plugin_package_files(root),
    )


def _meta_package_dependencies(root: Path) -> tuple[str, ...]:
    return (
        "arbiter-server",
        "arbiter-client",
        *(package.name for package in plugin_packages(root)),
    )


def _package_file_by_distribution(root: Path) -> dict[str, Path]:
    package_files = {
        "arbiter-server": Path("server/pyproject.toml"),
        "arbiter-client": Path("server/pyproject.toml"),
        "arbiter-skill": SKILL_PYPROJECT,
    }
    package_files.update(
        {
            package.name: package.path / "pyproject.toml"
            for package in plugin_packages(root)
            if package.path is not None
        }
    )
    return package_files


def _plugin_runtime_file(root: Path, plugin_path: Path, package_name: str) -> Path:
    module_name = package_name.replace("-", "_")
    candidate = plugin_path / "src" / module_name / "__init__.py"
    if (root / candidate).exists():
        return candidate

    for path in sorted((root / plugin_path / "src").glob("*/__init__.py")):
        relative_path = path.relative_to(root)
        if "SERVER_API_VERSION" in _read(root, relative_path):
            return relative_path
    return candidate


def _plugin_runtime_files(root: Path) -> tuple[Path, ...]:
    return tuple(
        _plugin_runtime_file(root, package.path, package.name)
        for package in plugin_packages(root)
        if package.path is not None
    )


def _replace_one(text: str, pattern: str, replacement: str, path: Path) -> str:
    updated, count = re.subn(pattern, replacement, text, count=1, flags=re.MULTILINE)
    if count != 1:
        raise ValueError(f"expected exactly one match in {path}: {pattern}")
    return updated


def _extract_version(text: str, path: Path) -> str:
    match = re.search(
        r'^version = "([0-9]+\.[0-9]+\.[0-9]+(?:[.-]dev[0-9]+)?)"$',
        text,
        re.MULTILINE,
    )
    if match is None:
        raise ValueError(f"could not find project version in {path}")
    return match.group(1)


def _version_line(version: str) -> ReleaseLine:
    return PackageVersion.parse(version).line


def _extract_server_dependency_range(text: str, path: Path) -> tuple[str, str]:
    match = re.search(
        r'"arbiter-server>=([0-9]+\.[0-9]+\.[0-9]+'
        r'(?:[.-]dev[0-9]+)?),<([0-9]+\.[0-9]+\.[0-9]+)"',
        text,
    )
    if match is None:
        raise ValueError(f"{path} is missing an arbiter-server dependency range")
    return match.group(1), match.group(2)


def _validate_current_state(root: Path) -> ReleaseLine:
    suite_pyproject = _read(root, SUITE_PYPROJECT)
    current_version = _extract_version(suite_pyproject, SUITE_PYPROJECT)
    current_line = _version_line(current_version)
    expected_next = current_line.next_version

    versions: dict[Path, str] = {}
    for path in _package_files(root):
        text = _read(root, path)
        found = _extract_version(text, path)
        found_line = _version_line(found)
        if found_line != current_line:
            raise ValueError(
                f"{path} version line {found_line.text} does not match "
                f"root line {current_line.text}"
            )
        versions[path] = found

    package_file_by_distribution = _package_file_by_distribution(root)
    for package_name in _meta_package_dependencies(root):
        package_version = versions[package_file_by_distribution[package_name]]
        dependency = f'"{package_name}=={package_version}"'
        if dependency not in suite_pyproject:
            raise ValueError(f"{SUITE_PYPROJECT} is missing dependency {dependency}")

    for path in _plugin_package_files(root):
        text = _read(root, path)
        lower_bound, upper_bound = _extract_server_dependency_range(text, path)
        lower_bound_line = _version_line(lower_bound)
        if lower_bound_line != current_line or upper_bound != expected_next:
            raise ValueError(
                f"{path} arbiter-server dependency must stay on line "
                f"{current_line.text} with upper bound <{expected_next}"
            )

    for path in _plugin_runtime_files(root):
        text = _read(root, path)
        if f'SERVER_API_VERSION = "{current_line.text}"' not in text:
            raise ValueError(f"{path} does not declare API line {current_line.text}")

    return current_line


def _validate_docs(root: Path, target: ReleaseLine, version: str) -> None:
    for path, expected_templates in DOC_EXPECTATIONS.items():
        text = _read(root, path)
        for expected_template in expected_templates:
            expected = expected_template.format(
                line=target.text,
                version=version,
                final_version=target.version,
                next_version=target.next_version,
                dev_version=f"{target.version}.dev1",
            )
            if expected not in text:
                raise ValueError(f"{path} is missing release text: {expected}")


def check_release_state(root: Path, target: ReleaseLine) -> str:
    current = _validate_current_state(root)
    if current != target:
        raise ValueError(
            f"target release line {target.text} does not match "
            f"current line {current.text}"
        )
    current_version = _extract_version(
        _read(root, SUITE_PYPROJECT),
        SUITE_PYPROJECT,
    )
    _validate_docs(root, target, current_version)
    return current_version


def _update_pyproject(
    text: str,
    path: Path,
    target: ReleaseLine,
    *,
    root: Path,
) -> str:
    updated = _replace_one(
        text,
        r'^version = "[0-9]+\.[0-9]+\.[0-9]+(?:[.-]dev[0-9]+)?"$',
        f'version = "{target.version}"',
        path,
    )
    if path == SUITE_PYPROJECT:
        for package_name in _meta_package_dependencies(root):
            updated = re.sub(
                rf'"{re.escape(package_name)}==[0-9]+\.[0-9]+\.[0-9]+'
                r'(?:[.-]dev[0-9]+)?"',
                f'"{package_name}=={target.version}"',
                updated,
            )
    if path in _plugin_package_files(root):
        updated = re.sub(
            r'"arbiter-server>=[0-9]+\.[0-9]+\.[0-9]+'
            r'(?:[.-]dev[0-9]+)?,<[0-9]+\.[0-9]+\.[0-9]+"',
            f'"arbiter-server>={target.version},<{target.next_version}"',
            updated,
        )
    return updated


def _update_runtime_file(
    text: str,
    path: Path,
    target: ReleaseLine,
) -> str:
    return _replace_one(
        text,
        r'^SERVER_API_VERSION = "[0-9]+\.[0-9]+"$',
        f'SERVER_API_VERSION = "{target.text}"',
        path,
    )


def _update_doc(
    text: str,
    current: ReleaseLine,
    target: ReleaseLine,
    current_version: str,
) -> str:
    updated = text
    updated = updated.replace(
        f">={current.version},<{current.next_version}",
        f">={target.version},<{target.next_version}",
    )
    updated = updated.replace(
        f">={current_version},<{current.next_version}",
        f">={target.version},<{target.next_version}",
    )
    replacements = (
        (current_version, target.version),
        (current.version, target.version),
        (f"{current.text}.x", f"{target.text}.x"),
        (f"{current.text}.1", f"{target.text}.1"),
        (f"{current.text}`", f"{target.text}`"),
        (f'"{current.text}"', f'"{target.text}"'),
    )
    for old, new in replacements:
        updated = updated.replace(old, new)
    updated = updated.replace(
        f"dev version such as `{target.version}`",
        f"dev version such as `{target.version}.dev1`",
    )
    updated = re.sub(
        rf"such as `{re.escape(target.version)}`,\s*"
        rf"`{re.escape(target.version)}`, or "
        rf"(`{re.escape(target.text)}\.1`[,.])",
        rf"such as `{target.version}` or\n\1",
        updated,
    )
    return updated


def build_changes(root: Path, target: ReleaseLine) -> list[Change]:
    current = _validate_current_state(root)
    current_version_text = _extract_version(
        _read(root, SUITE_PYPROJECT),
        SUITE_PYPROJECT,
    )
    current_version = PackageVersion.parse(current_version_text)
    target_version = PackageVersion.final_for_line(target)
    if current_version >= target_version:
        raise ValueError(
            f"target release line {target.text} must be greater than "
            f"current line {current.text}"
        )

    changes: list[Change] = []
    for path in _package_files(root):
        before = _read(root, path)
        after = _update_pyproject(before, path, target, root=root)
        if after != before:
            changes.append(Change(path=path, before=before, after=after))

    for path in _plugin_runtime_files(root):
        before = _read(root, path)
        after = _update_runtime_file(before, path, target)
        if after != before:
            changes.append(Change(path=path, before=before, after=after))

    for path in DOC_FILES:
        before = _read(root, path)
        after = _update_doc(before, current, target, current_version_text)
        if after != before:
            changes.append(Change(path=path, before=before, after=after))

    return changes


def _print_diff(changes: list[Change]) -> None:
    for change in changes:
        diff = difflib.unified_diff(
            change.before.splitlines(keepends=True),
            change.after.splitlines(keepends=True),
            fromfile=str(change.path),
            tofile=str(change.path),
        )
        sys.stdout.writelines(diff)


def _write_changes(root: Path, changes: list[Change]) -> None:
    for change in changes:
        (root / change.path).write_text(change.after, encoding="utf-8")


def _can_encode(text: str, stream: TextIO) -> bool:
    encoding = stream.encoding or "utf-8"
    try:
        text.encode(encoding)
    except UnicodeEncodeError:
        return False
    return True


def _success(message: str) -> str:
    symbol = "✓" if _can_encode("✓", sys.stdout) else "OK"
    return f"{GREEN}{symbol}{RESET} {message}"


def _failure(message: str) -> str:
    symbol = "✗" if _can_encode("✗", sys.stderr) else "ERROR"
    return f"{RED}{symbol}{RESET} {message}"


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Upgrade Arbiter packages and docs to a new " "MAJOR.MINOR release line."
        )
    )
    parser.add_argument("release_line", help="target release line, for example 0.9")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print the patch without changing files",
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="verify files already match the requested release line",
    )
    parser.add_argument(
        "--root",
        default=".",
        help=argparse.SUPPRESS,
    )
    namespace = parser.parse_args(argv)

    try:
        target = ReleaseLine.parse(namespace.release_line)
        root = Path(namespace.root).resolve()
        if namespace.check:
            current_version = check_release_state(root, target)
            print(
                _success(
                    f"release line check passed: {target.text} ({current_version})"
                )
            )
            return 0
        changes = build_changes(root, target)
    except (FileNotFoundError, OSError, ValueError) as exc:
        print(_failure(f"upgrade_release_line: {exc}"), file=sys.stderr)
        return 1

    if namespace.dry_run:
        _print_diff(changes)
        print(_success(f"would update {len(changes)} file(s)"))
        return 0

    _write_changes(root, changes)
    for change in changes:
        print(f"updated {change.path}")
    print(_success(f"release line is now {target.text} ({target.version})"))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
