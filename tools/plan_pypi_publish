#!/usr/bin/env python3
from __future__ import annotations

import argparse
from functools import total_ordering
import json
import os
import re
import shutil
import sys
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

try:
    from tomllib import loads as load_toml  # type: ignore[import-not-found]
except ModuleNotFoundError:  # pragma: no cover - exercised on Python 3.10.
    from tomli import loads as load_toml

from release_packages import (  # noqa: E402
    CLIENT_PLATFORM_TAGS,
    Package,
    package_by_key,
    package_key_by_name,
    package_keys,
    release_packages,
)


@total_ordering
@dataclass(frozen=True)
class Version:
    major: int
    minor: int
    patch: int
    dev: int | None = None

    @classmethod
    def parse(cls, value: str) -> "Version":
        match = re.fullmatch(
            r"(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)"
            r"(?:[.-]dev(0|[1-9][0-9]*))?",
            value,
        )
        if match is None:
            raise ValueError(
                "only MAJOR.MINOR.PATCH and MAJOR.MINOR.PATCH.devN versions "
                f"are supported: {value}"
            )
        return cls(
            major=int(match.group(1)),
            minor=int(match.group(2)),
            patch=int(match.group(3)),
            dev=int(match.group(4)) if match.group(4) is not None else None,
        )

    def _sort_key(self) -> tuple[int, int, int, int, int]:
        return (
            self.major,
            self.minor,
            self.patch,
            1 if self.dev is None else 0,
            self.dev or 0,
        )

    def __lt__(self, other: object) -> bool:
        if not isinstance(other, Version):
            return NotImplemented
        return self._sort_key() < other._sort_key()

    @property
    def line(self) -> tuple[int, int]:
        return (self.major, self.minor)

    @property
    def text(self) -> str:
        version = f"{self.major}.{self.minor}.{self.patch}"
        if self.dev is not None:
            version = f"{version}.dev{self.dev}"
        return version


@dataclass(frozen=True)
class PlanItem:
    package: Package
    local_version: Version
    pypi_version: Version | None
    publish: bool
    reason: str


def _read_project(root: Path, package: Package) -> dict[str, object]:
    if package.path is None:
        raise ValueError(f"{package.name} does not have a pyproject path")
    pyproject = root / package.path / "pyproject.toml"
    if not pyproject.exists():
        raise FileNotFoundError(f"missing package pyproject: {pyproject}")
    data = load_toml(pyproject.read_text(encoding="utf-8"))
    project = data.get("project")
    if not isinstance(project, dict):
        raise ValueError(f"{pyproject} is missing [project]")
    name = project.get("name")
    if name != package.expected_project_name:
        raise ValueError(
            f"{pyproject} project name is {name!r}, "
            f"expected {package.expected_project_name!r}"
        )
    return project


def _project_version(root: Path, package: Package) -> Version:
    version = _read_project(root, package).get("version")
    if not isinstance(version, str):
        raise ValueError(
            f"{package.path / 'pyproject.toml'} is missing project.version"
        )
    return Version.parse(version)


def _pypi_version(package_name: str) -> Version | None:
    url = f"https://pypi.org/pypi/{package_name}/json"
    try:
        with urllib.request.urlopen(url, timeout=15) as response:
            payload = json.load(response)
    except urllib.error.HTTPError as exc:
        if exc.code == 404:
            return None
        raise

    info = payload.get("info")
    if not isinstance(info, dict):
        raise ValueError(f"unexpected PyPI response for {package_name}: missing info")
    version = info.get("version")
    if not isinstance(version, str):
        raise ValueError(
            f"unexpected PyPI response for {package_name}: missing version"
        )
    return Version.parse(version)


def _validate_versions(root: Path) -> dict[str, Version]:
    packages = release_packages(root)
    versions = {package.name: _project_version(root, package) for package in packages}
    server_version = versions["arbiter-server"]

    main_version = versions["arbiter-suite"]
    if main_version.line != server_version.line:
        raise ValueError(
            "arbiter-suite version line "
            f"{main_version.major}.{main_version.minor} does not match server "
            f"{server_version.major}.{server_version.minor}"
        )

    for package in packages:
        if package.kind != "plugin":
            continue
        line_version = versions[package.name]
        if line_version.line != server_version.line:
            raise ValueError(
                f"{package.name} version line "
                f"{line_version.major}.{line_version.minor} does not match server "
                f"{server_version.major}.{server_version.minor}"
            )

    return versions


def _distribution_patterns(package: Package, version: Version) -> tuple[str, ...]:
    base = f"{package.normalized_name}-{version.text}"
    if package.kind == "client":
        return tuple(f"{base}-py3-none-{tag}.whl" for tag in CLIENT_PLATFORM_TAGS)

    filenames: list[str] = []
    if "sdist" in package.artifacts:
        filenames.append(f"{base}.tar.gz")
    if "wheel" in package.artifacts:
        filenames.append(f"{base}-py3-none-any.whl")
    return tuple(filenames)


def _copy_distributions(
    *,
    dist_dir: Path,
    output_dir: Path,
    item: PlanItem,
) -> list[Path]:
    copied: list[Path] = []
    for filename in _distribution_patterns(item.package, item.local_version):
        source = dist_dir / filename
        if not source.exists():
            raise FileNotFoundError(
                f"expected built distribution is missing: {source}; "
                "build distributions first, or omit --prepare-output-dir when "
                "you only want to query the publish plan"
            )
        target = output_dir / filename
        shutil.copy2(source, target)
        copied.append(target)
    return copied


def _parse_package_keys(
    value: str,
    *,
    root: Path | None = None,
) -> frozenset[str] | None:
    value = value.strip()
    if value == "all":
        return None

    root = root or Path.cwd()
    known_keys = package_keys(root)
    keys = frozenset(key.strip() for key in value.split(",") if key.strip())
    if not keys:
        raise ValueError("--packages must be 'all' or a comma-separated key list")
    if "all" in keys:
        raise ValueError("--packages cannot combine 'all' with package keys")

    unknown = sorted(keys - set(known_keys))
    if unknown:
        expected = ", ".join(("all", *known_keys))
        raise ValueError(
            f"unknown package key in --packages: {', '.join(unknown)} "
            f"(expected one or more of: {expected})"
        )
    return keys


def build_plan(
    root: Path,
    *,
    package_keys: frozenset[str] | None = None,
) -> list[PlanItem]:
    packages = release_packages(root)
    packages_by_key = package_by_key(root)
    versions = _validate_versions(root)
    selected_package_names = (
        {packages_by_key[key].name for key in package_keys}
        if package_keys is not None
        else None
    )
    plan: list[PlanItem] = []
    for package in packages:
        local_version = versions[package.name]
        if (
            selected_package_names is not None
            and package.name not in selected_package_names
        ):
            plan.append(
                PlanItem(
                    package=package,
                    local_version=local_version,
                    pypi_version=None,
                    publish=False,
                    reason="not selected by --packages",
                )
            )
            continue

        pypi_version = _pypi_version(package.name)
        if pypi_version is None:
            publish = True
            reason = "project is not on PyPI"
        elif local_version > pypi_version:
            publish = True
            reason = (
                f"local {local_version.text} is newer than PyPI {pypi_version.text}"
            )
        elif local_version == pypi_version:
            publish = False
            reason = f"local {local_version.text} is already on PyPI"
        else:
            raise ValueError(
                f"{package.name} local version {local_version.text} is older than "
                f"PyPI {pypi_version.text}"
            )
        plan.append(
            PlanItem(
                package=package,
                local_version=local_version,
                pypi_version=pypi_version,
                publish=publish,
                reason=reason,
            )
        )
    return plan


def _write_github_output(
    path: str | None,
    *,
    publish_count: int,
    publish_keys: list[str],
    publish_specs: list[str],
    publish_title: str,
) -> None:
    if not path:
        return
    with Path(path).open("a", encoding="utf-8") as output:
        output.write(f"publish_count={publish_count}\n")
        output.write(f"has_publish={'true' if publish_count else 'false'}\n")
        output.write(f"publish_keys={','.join(publish_keys)}\n")
        output.write(f"publish_specs={','.join(publish_specs)}\n")
        output.write(f"publish_title={publish_title}\n")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Plan a selective PyPI publish by comparing local package versions "
            "to the versions currently visible on PyPI."
        )
    )
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument("--dist-dir", default="dist")
    parser.add_argument("--output-dir", default="dist-publish")
    parser.add_argument(
        "--packages",
        default="all",
        metavar="KEYS",
        help=(
            "limit publishing to 'all' or comma-separated package keys "
            "(run with an invalid key to see the currently discovered keys)"
        ),
    )
    parser.add_argument(
        "--prepare-output-dir",
        action="store_true",
        help="copy selected distributions into the output directory",
    )
    namespace = parser.parse_args(argv)

    try:
        root = Path(namespace.root).resolve()
        package_keys = _parse_package_keys(namespace.packages, root=root)
        plan = build_plan(root, package_keys=package_keys)
        publish_items = [item for item in plan if item.publish]
        keys_by_name = package_key_by_name(root)
        publish_keys = [keys_by_name[item.package.name] for item in publish_items]
        publish_specs = [
            f"{item.package.name}=={item.local_version.text}" for item in publish_items
        ]
        publish_title = ", ".join(
            f"{item.package.name} {item.local_version.text}" for item in publish_items
        )

        if namespace.prepare_output_dir:
            output_dir = root / namespace.output_dir
            if output_dir.exists():
                shutil.rmtree(output_dir)
            output_dir.mkdir(parents=True)
            dist_dir = root / namespace.dist_dir
            for item in publish_items:
                _copy_distributions(
                    dist_dir=dist_dir,
                    output_dir=output_dir,
                    item=item,
                )

        for item in plan:
            action = "publish" if item.publish else "skip"
            print(
                f"{action}: {item.package.name} {item.local_version.text} "
                f"({item.reason})"
            )

        print(f"publish_count={len(publish_items)}")
        _write_github_output(
            os.environ.get("GITHUB_OUTPUT"),
            publish_count=len(publish_items),
            publish_keys=publish_keys,
            publish_specs=publish_specs,
            publish_title=publish_title,
        )
        return 0
    except (FileNotFoundError, ValueError, urllib.error.URLError) as exc:
        print(f"plan_pypi_publish: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
