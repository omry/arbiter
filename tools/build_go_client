#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


@dataclass(frozen=True)
class Target:
    goos: str
    goarch: str

    @property
    def label(self) -> str:
        return f"{self.goos}-{self.goarch}"

    @property
    def binary_name(self) -> str:
        if self.goos == "windows":
            return "arbiter.exe"
        return "arbiter"


DEFAULT_TARGETS = (
    Target("linux", "amd64"),
    Target("linux", "arm64"),
    Target("darwin", "amd64"),
    Target("darwin", "arm64"),
    Target("windows", "amd64"),
    Target("windows", "arm64"),
)


def parse_target(value: str) -> Target:
    parts = value.split("-")
    if len(parts) != 2 or not all(parts):
        raise argparse.ArgumentTypeError(
            f"invalid target {value!r}; expected GOOS-GOARCH, such as linux-amd64"
        )
    return Target(parts[0], parts[1])


def run(
    command: list[str],
    *,
    cwd: Path,
    env: dict[str, str] | None = None,
    verbose: bool,
) -> None:
    if verbose:
        display_env = ""
        if env is not None:
            display_env = " ".join(
                f"{name}={value}"
                for name, value in sorted(env.items())
                if name in {"GOOS", "GOARCH", "CGO_ENABLED"}
            )
        prefix = f"{display_env} " if display_env else ""
        print(f"+ {prefix}{' '.join(command)}", flush=True)
    subprocess.run(command, cwd=cwd, env=env, check=True)


def display_path(path: Path, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def build_targets(
    *,
    root: Path,
    outdir: Path,
    targets: tuple[Target, ...],
    clean: bool,
    generate: bool,
    strip: bool,
    verbose: bool,
) -> list[Path]:
    client_dir = root / "client-go"
    if not (client_dir / "go.mod").exists():
        raise FileNotFoundError(f"missing Go client module: {client_dir / 'go.mod'}")

    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    if generate:
        run(["go", "generate", "./internal/cli"], cwd=client_dir, verbose=verbose)

    built: list[Path] = []
    base_env = os.environ.copy()
    for target in targets:
        target_dir = outdir / target.label
        target_dir.mkdir(parents=True, exist_ok=True)
        output = target_dir / target.binary_name
        env = base_env.copy()
        env.update(
            {
                "CGO_ENABLED": "0",
                "GOOS": target.goos,
                "GOARCH": target.goarch,
            }
        )
        command = [
            "go",
            "build",
            "-buildvcs=false",
            "-trimpath",
        ]
        if strip:
            command.extend(["-ldflags", "-s -w"])
        command.extend(
            [
                "-o",
                str(output),
                "./cmd/arbiter",
            ]
        )
        run(
            command,
            cwd=client_dir,
            env=env,
            verbose=verbose,
        )
        built.append(output)
        print(f"built {display_path(output, root)}")
    return built


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Build native Arbiter Go client binaries for release targets."
    )
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument(
        "--outdir",
        default="client-go/dist",
        help="output directory, default: client-go/dist",
    )
    parser.add_argument(
        "--target",
        action="append",
        type=parse_target,
        metavar="GOOS-GOARCH",
        help=(
            "build one target, such as linux-amd64; may be passed more than once. "
            "Defaults to linux/darwin/windows for amd64 and arm64."
        ),
    )
    parser.add_argument(
        "--skip-generate",
        action="store_true",
        help="skip go generate ./internal/cli before building",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before building",
    )
    parser.add_argument(
        "--debug",
        action="store_true",
        help="include debug symbols instead of stripping release binaries",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="print commands before running them",
    )
    namespace = parser.parse_args(argv)

    root = Path(namespace.root).resolve()
    outdir = Path(namespace.outdir)
    if not outdir.is_absolute():
        outdir = root / outdir
    targets = tuple(namespace.target or DEFAULT_TARGETS)

    try:
        build_targets(
            root=root,
            outdir=outdir,
            targets=targets,
            clean=namespace.clean,
            generate=not namespace.skip_generate,
            strip=not namespace.debug,
            verbose=namespace.verbose,
        )
    except (OSError, subprocess.CalledProcessError) as exc:
        print(f"build_go_client: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
